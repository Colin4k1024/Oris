{
  "title": "Oris Runtime Overview",
  "uid": "oris-runtime-overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "tags": ["oris", "runtime", "observability"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Queue Depth And Backpressure",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "refId": "A",
          "expr": "oris_runtime_queue_depth",
          "legendFormat": "queue depth"
        },
        {
          "refId": "B",
          "expr": "sum by (reason) (increase(oris_runtime_backpressure_total[5m]))",
          "legendFormat": "backpressure {{reason}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Dispatch Latency P95",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oris_runtime_dispatch_latency_ms_bucket[5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 3,
      "title": "Recovery Latency P95",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oris_runtime_recovery_latency_ms_bucket[10m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 4,
      "title": "Error And Lease Conflict Rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "refId": "A",
          "expr": "oris_runtime_terminal_error_rate",
          "legendFormat": "terminal error rate"
        },
        {
          "refId": "B",
          "expr": "oris_runtime_lease_conflict_rate",
          "legendFormat": "lease conflict rate"
        }
      ]
    },
    {
      "id": 5,
      "title": "A2A Compat Queue And Lease Expiry",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "refId": "A",
          "expr": "oris_a2a_task_queue_depth",
          "legendFormat": "compat queue depth"
        },
        {
          "refId": "B",
          "expr": "increase(oris_a2a_task_lease_expired_total[5m])",
          "legendFormat": "lease expired reclaimed (5m)"
        }
      ]
    },
    {
      "id": 6,
      "title": "A2A Compat Claim And Report Latency P95",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oris_a2a_task_claim_latency_ms_bucket[5m])))",
          "legendFormat": "claim latency p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(oris_a2a_report_to_capture_latency_ms_bucket[5m])))",
          "legendFormat": "report->capture latency p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 7,
      "title": "A2A Compat Endpoint Throughput (5m)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "refId": "A",
          "expr": "increase(oris_a2a_fetch_total[5m])",
          "legendFormat": "fetch"
        },
        {
          "refId": "B",
          "expr": "increase(oris_a2a_task_claim_total[5m])",
          "legendFormat": "task claim"
        },
        {
          "refId": "C",
          "expr": "increase(oris_a2a_task_complete_total[5m])",
          "legendFormat": "task complete"
        },
        {
          "refId": "D",
          "expr": "increase(oris_a2a_work_claim_total[5m])",
          "legendFormat": "work claim"
        },
        {
          "refId": "E",
          "expr": "increase(oris_a2a_work_complete_total[5m])",
          "legendFormat": "work complete"
        },
        {
          "refId": "F",
          "expr": "increase(oris_a2a_heartbeat_total[5m])",
          "legendFormat": "heartbeat"
        }
      ]
    }
  ]
}
